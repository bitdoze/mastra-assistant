{
  "name": "mastra-assistant",
  "version": "1.0.0",
  "description": "Lean Mastra assistant with TinyFish, YouTube, and GitHub tools. Memory with LibSQL/Turso + DuckDB. Self-hosted on macOS or Linux.",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "mastra dev",
    "build": "mastra build --studio",
    "start": "MASTRA_STUDIO_PATH=.mastra/output/studio node .mastra/output/index.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mastra/core": "^1.51.0",
    "@mastra/duckdb": "^1.5.1",
    "@mastra/editor": "^0.13.7",
    "@mastra/fastembed": "^1.2.0",
    "@mastra/libsql": "^1.16.0",
    "@mastra/loggers": "^1.2.0",
    "@mastra/memory": "^1.23.0",
    "@mastra/observability": "^1.16.1",
    "@tiny-fish/sdk": "^0.0.11",
    "youtube-transcript-scraper": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "mastra": "^1.19.0",
    "typescript": "^7.0.2"
  }
}
