# OpenRouter — provides access to hundreds of models including free tiers.
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model to use (provider/model format). Defaults to google/gemini-2.5-flash.
# Free options:
#   google/gemini-2.5-flash
#   meta-llama/llama-3.3-70b-instruct:free
#   qwen/qwen3-coder:free
#   openai/gpt-oss-120b:free
AGENT_MODEL=google/gemini-2.5-flash

# TinyFish — web search and page fetch tools.
# Get your key at https://tinyfish.com
TINYFISH_API_KEY=

# GitHub — for trending and repo tools. Optional but recommended
# (raises rate limits from 60 to 5000 req/hr).
# Create a token at https://github.com/settings/tokens (classic, no scopes needed)
GITHUB_TOKEN=

# Turso (libSQL) database for storage + memory vectors.
# Use file:./mastra.db for local development.
# For production, create a Turso DB: https://turso.tech
TURSO_DATABASE_URL=file:./mastra.db
TURSO_AUTH_TOKEN=

# Optional: override the workspace directory (default: ./workspace)
# ASSISTANT_WORKSPACE_DIR=

# Optional: agent timezone for date/time in system prompt (e.g. Europe/Bucharest)
# AGENT_TIMEZONE=

# Optional: max agentic steps per call (default: 20)
# AGENT_MAX_STEPS=20

# Mastra Platform deploy (optional, set when deploying to Mastra Cloud)
# MASTRA_PLATFORM_ACCESS_TOKEN=
